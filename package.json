{
    "name": "qapi",
    "main": "src/main.ts",
    "scripts": {
        "key": "bun cli/keys.ts",
        "dev": "bun apidev",
        "apidev": "bun --watch src/main.ts",
        "prep": "bunx --bun @tailwindcss/cli -i ./src/ui/index.css -o ./src/ui/tailwind.css",
        "appdev": "bunx --bun @tailwindcss/cli -i ./src/ui/index.css -o ./src/ui/tailwind.css --watch"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.1",
        "@types/bun": "^1.3.10",
        "tailwindcss": "^4.2.1"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.1",
        "@elysiajs/openapi": "^1.4.14",
        "elysia": "^1.4.26",
        "enquirer": "^2.4.1"
    }
}